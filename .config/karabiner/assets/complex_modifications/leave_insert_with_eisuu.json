{
  "title": "Leave INSERT mode with EISUU",
  "rules": [
    {
      "description": "Ctrl+- -> Leave INSERT mode with EISUU",
      "manipulators": [
        {
          "conditions": [
            {
              "bundle_identifiers": [
                "com.googlecode.iterm2",
                "md.obsidian",
                "com.mitchellh.ghostty",
                "com.cmuxterm.app"
              ],
              "type": "frontmost_application_if"
            }
          ],
          "from": {
            "key_code": "hyphen",
            "modifiers": {
              "mandatory": [
                "left_control"
              ]
            }
          },
          "to": [
            {
              "key_code": "japanese_eisuu"
            },
            {
              "key_code": "escape"
            }
          ],
          "type": "basic"
        }
      ]
    }
  ]
}
